{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "secrets": {
          "fileSecrets": {
            "GOOGLE_SERVICES_JSON": "./google-services.json"
          }
        }
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "secrets": {
          "fileSecrets": {
            "GOOGLE_SERVICES_JSON": "./google-services.json"
          }
        }
      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "secrets": {
          "fileSecrets": {
            "GOOGLE_SERVICES_JSON": "./google-services.json"
          }
        }
      }
    }
  },
  "submit": {
    "production": {}
  }
}
