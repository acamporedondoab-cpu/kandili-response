{
  "expo": {
    "name": "Guardian Dispatch",
    "slug": "guardian-dispatch",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "@react-native-firebase/app",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Guardian Dispatch needs your location to send help to the right place.",
          "locationWhenInUsePermission": "Guardian Dispatch needs your location to send help to the right place."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#DC2626",
          "sounds": []
        }
      ]
    ],
    "ios": {
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Guardian Dispatch needs your location to send help to the right place.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Guardian Dispatch needs your location to track responders in real-time."
      }
    },
    "android": {
      "package": "com.automateph.guardiandispatch",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDpuJbk-bFwo-Zee4nWoa561YBhrhcPyYI"
        }
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "5eb7b2f3-4f64-40e3-b2ff-e2feee4578ae"
      }
    }
  }
}
