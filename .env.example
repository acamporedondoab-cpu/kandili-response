# ============================================================
# Guardian Dispatch — Environment Variable Reference
# ============================================================
# Copy the relevant section into the correct env file.
# NEVER commit .env or .env.local files with real values.
# ============================================================

# ------------------------------------------------------------
# Next.js Web App  →  app/.env.local
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # Server-side only. Never prefix with NEXT_PUBLIC_.

# Sprint 1B — added when Firebase and Google Maps are configured:
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# FIREBASE_SERVICE_ACCOUNT stored in Supabase Edge Function secrets — not here.

# ------------------------------------------------------------
# Expo Mobile App  →  mobile/.env
# ------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Sprint 1B — added when Firebase and Google Maps are configured:
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
